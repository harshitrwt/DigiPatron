# Backend (FastAPI)
# If you run from `DigiWarden/backend`, defaults already work.
STORAGE_PATH=./data
# For Windows absolute paths, use forward slashes, e.g. sqlite:///C:/path/to/contentgenome.db
DB_URL=sqlite:///./data/contentgenome.db
ENABLE_DEMO_VARIANTS=true

# Google APIs (all free-tier)
# Get Gemini API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Get from: https://developers.google.com/custom-search/v1/introduction
GOOGLE_CSE_API_KEY=
# Get from: https://programmablesearchengine.google.com
GOOGLE_CSE_ID=

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000/api

